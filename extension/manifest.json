{
  "manifest_version": 3,
  "name": "CellManager CRM Extension",
  "version": "5.0",
  "description": "Integração oficial CellManager CRM para WhatsApp e Instagram.",
  "permissions": ["storage", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*", "https://www.instagram.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": ["https://*.supabase.co/*"]
}
